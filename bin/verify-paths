#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const glob = require('glob');

// Find the project root (where tsconfig.json is located)
function findProjectRoot() {
  let currentDir = process.cwd();
  const rootIndicators = ['tsconfig.json', 'package.json', 'next.config.js'];
  
  while (currentDir !== '/') {
    const hasRootFile = rootIndicators.some(file => 
      fs.existsSync(path.join(currentDir, file))
    );
    
    if (hasRootFile) {
      return currentDir;
    }
    
    // Go up one directory
    currentDir = path.dirname(currentDir);
  }
  
  // If we can't find a project root, use current directory
  return process.cwd();
}

// Get the project root
const projectRoot = findProjectRoot();
console.log(`Project root found at: ${projectRoot}`);

// Change to project root
process.chdir(projectRoot);

// Get the filename from command line argument
const targetFileName = process.argv[2];
if (!targetFileName) {
  console.error('Please provide a file name to check.');
  console.error('Usage: verify-paths <file-name>');
  process.exit(1);
}

// Find the file in the project
const findFiles = glob.sync(`**/${targetFileName}`, {
  ignore: ['node_modules/**', '.next/**', 'out/**', 'build/**', 'verify-paths.js'],
  nodir: true
});

if (findFiles.length === 0) {
  console.error(`Error: File '${targetFileName}' not found in project.`);
  process.exit(1);
} else if (findFiles.length > 1) {
  console.log(`Found multiple files matching '${targetFileName}':`);
  findFiles.forEach((file, index) => {
    console.log(`${index + 1}. ${file}`);
  });
  
  // Allow the user to choose which file to check
  process.stdout.write('\nEnter number to choose (default: 1): ');
  
  // For simplicity, we'll automatically use the first one
  console.log("1");
}

const targetFile = findFiles[0];

// Read tsconfig.json
let tsconfig;
try {
  tsconfig = JSON.parse(fs.readFileSync('tsconfig.json', 'utf8'));
} catch (err) {
  console.error('Error reading tsconfig.json file:', err.message);
  process.exit(1);
}

const baseUrl = tsconfig.compilerOptions.baseUrl || '.';
const pathMappings = tsconfig.compilerOptions.paths || {};

// Convert path mappings to a more usable format
const aliasMap = {};
Object.entries(pathMappings).forEach(([alias, targets]) => {
  // Remove trailing /* from alias and target
  const cleanAlias = alias.replace(/\/\*$/, '');
  const cleanTargets = targets.map(target => target.replace(/\/\*$/, ''));
  aliasMap[cleanAlias] = cleanTargets;
});

// Function to check if a directory exists
function directoryExists(dirPath) {
  try {
    return fs.statSync(dirPath).isDirectory();
  } catch (err) {
    return false;
  }
}

// Function to check if a file exists
function fileExists(filePath) {
  try {
    return fs.statSync(filePath).isFile();
  } catch (err) {
    return false;
  }
}

// Regular expression to match import statements
const importRegex = /import\s+(?:(?:\w+(?:\s*,\s*{[^}]*})?)|(?:{[^}]*}))\s+from\s+['"]([^'"]+)['"]/g;

// Regular expression to match dynamic imports
const dynamicImportRegex = /import\s*\(\s*['"]([^'"]+)['"]\s*\)/g;

// Results storage
const results = {
  valid: [],
  invalid: []
};

// Read the content of the file
let content;
try {
  content = fs.readFileSync(targetFile, 'utf8');
} catch (err) {
  console.error(`Error reading file ${targetFile}:`, err.message);
  process.exit(1);
}

// Find all imports
const imports = [];
let match;

// Extract static imports
while ((match = importRegex.exec(content)) !== null) {
  imports.push(match[1]);
}

// Extract dynamic imports
while ((match = dynamicImportRegex.exec(content)) !== null) {
  imports.push(match[1]);
}

// Skip files with no imports
if (imports.length === 0) {
  console.log(`No imports found in ${targetFile}`);
  process.exit(0);
}

// Validate each import
imports.forEach(importPath => {
  // Skip node modules and relative imports
  if (importPath.startsWith('.') || !importPath.startsWith('@')) return;
  
  let isValid = false;
  let resolvedPath = null;
  
  // Check if the import uses one of our aliases
  for (const [alias, targets] of Object.entries(aliasMap)) {
    if (importPath.startsWith(alias)) {
      // Replace the alias with its target path
      const pathAfterAlias = importPath.slice(alias.length);
      
      // Try each potential target path
      for (const target of targets) {
        const potentialPath = path.join(baseUrl, target + pathAfterAlias);
        
        // Check various extensions and index files
        const possiblePaths = [
          potentialPath,
          potentialPath + '.js',
          potentialPath + '.jsx',
          potentialPath + '.ts',
          potentialPath + '.tsx',
          path.join(potentialPath, 'index.js'),
          path.join(potentialPath, 'index.jsx'),
          path.join(potentialPath, 'index.ts'),
          path.join(potentialPath, 'index.tsx')
        ];
        
        for (const p of possiblePaths) {
          if (fileExists(p)) {
            isValid = true;
            resolvedPath = p;
            break;
          }
        }
        
        // Check if it's a directory without an index file
        if (!isValid && directoryExists(potentialPath)) {
          isValid = true;
          resolvedPath = potentialPath + ' (directory)';
        }
        
        if (isValid) break;
      }
      
      break;
    }
  }
  
  // Store the result
  if (isValid) {
    results.valid.push({
      import: importPath,
      resolvedPath
    });
  } else {
    results.invalid.push({
      import: importPath
    });
  }
});

// Print results
console.log(`\n====== PATH VERIFICATION RESULTS FOR ${targetFile} ======`);
console.log(`\nFound ${results.valid.length} valid imports and ${results.invalid.length} potentially invalid imports.\n`);

// Display all imports found in the file
console.log('ALL IMPORTS:');
const allImports = [...results.valid, ...results.invalid].sort((a, b) => 
  a.import.localeCompare(b.import)
);

allImports.forEach(item => {
  const status = results.valid.some(valid => valid.import === item.import) ? 'VALID' : 'INVALID';
  const statusColor = status === 'VALID' ? '\x1b[32m' : '\x1b[31m'; // Green for valid, red for invalid
  const resetColor = '\x1b[0m';
  
  console.log(`${statusColor}[${status}]${resetColor} "${item.import}"`);
  
  if (status === 'VALID') {
    const validItem = results.valid.find(valid => valid.import === item.import);
    if (validItem && validItem.resolvedPath) {
      console.log(`  → Resolves to: ${validItem.resolvedPath}`);
    }
  }
});

// Detailed analysis for invalid imports
if (results.invalid.length > 0) {
  console.log('\n====== INVALID IMPORTS ANALYSIS ======');
  
  results.invalid.forEach(item => {
    console.log(`\nAnalyzing: "${item.import}"`);
    
    // Check which alias is being used
    const usedAlias = Object.keys(aliasMap).find(alias => 
      item.import.startsWith(alias)
    );
    
    if (usedAlias) {
      console.log(`Using alias: "${usedAlias}"`);
      console.log(`Mapping to: ${JSON.stringify(aliasMap[usedAlias])}`);
      
      // Check path after alias
      const pathAfterAlias = item.import.slice(usedAlias.length);
      console.log(`Path after alias: "${pathAfterAlias}"`);
      
      // Try each potential target path
      aliasMap[usedAlias].forEach(target => {
        const potentialPath = path.join(baseUrl, target + pathAfterAlias);
        console.log(`Checking: ${potentialPath}`);
        
        // Check if directory exists
        if (directoryExists(potentialPath)) {
          console.log(`  ✓ Directory exists: ${potentialPath}`);
          
          // Check for index files
          ['index.js', 'index.jsx', 'index.ts', 'index.tsx'].forEach(indexFile => {
            const indexPath = path.join(potentialPath, indexFile);
            if (fileExists(indexPath)) {
              console.log(`  ✓ Index file exists: ${indexPath}`);
            }
          });
        } else {
          console.log(`  ✗ Directory not found: ${potentialPath}`);
        }
        
        // Check for file with extensions
        ['.js', '.jsx', '.ts', '.tsx', ''].forEach(ext => {
          const filePath = potentialPath + ext;
          if (fileExists(filePath)) {
            console.log(`  ✓ File exists: ${filePath}`);
          }
        });
      });
      
      // Suggest possible fixes
      console.log('\nPossible fixes:');
      
      // Check for typos in the path
      const correctPath = findClosestPath(item.import, usedAlias, aliasMap[usedAlias], baseUrl);
      if (correctPath) {
        console.log(`1. Did you mean: "${correctPath}"?`);
      }
      
      // Check if the file exists at a different location
      console.log(`2. Check if the file exists at the expected location: ${path.join(baseUrl, aliasMap[usedAlias][0] + item.import.slice(usedAlias.length))}`);
      
      // Check if the alias is correct
      const possibleAliases = Object.keys(aliasMap).filter(a => a !== usedAlias && a !== '@/');
      if (possibleAliases.length > 0) {
        console.log(`3. Try a different alias: ${possibleAliases.join(', ')}`);
      }
    } else {
      console.log('No matching alias found in tsconfig.json paths.');
      console.log('Available aliases:');
      Object.keys(aliasMap).forEach(alias => {
        console.log(`  - ${alias}`);
      });
    }
  });
}

// Helper function to find closest valid path
function findClosestPath(importPath, alias, targets, baseUrl) {
  // This is a simple implementation - in a real scenario you might want to use 
  // a more sophisticated algorithm like Levenshtein distance
  const pathAfterAlias = importPath.slice(alias.length);
  
  // Check common typos
  const typos = [
    { wrong: 'componets', right: 'components' },
    { wrong: 'component', right: 'components' },
    { wrong: 'compnents', right: 'components' },
    { wrong: 'General Components', right: 'general' },
    { wrong: 'general Components', right: 'general' },
    { wrong: 'General Component', right: 'general' },
    { wrong: 'page/components', right: 'components' }
  ];
  
  for (const {wrong, right} of typos) {
    if (pathAfterAlias.includes(wrong)) {
      const correctedPath = pathAfterAlias.replace(wrong, right);
      
      // Check if the corrected path exists
      for (const target of targets) {
        const potentialPath = path.join(baseUrl, target + correctedPath);
        
        // Check with various extensions
        for (const ext of ['', '.js', '.jsx', '.ts', '.tsx']) {
          if (fileExists(potentialPath + ext)) {
            return alias + correctedPath;
          }
        }
        
        // Check for index files
        for (const indexFile of ['index.js', 'index.jsx', 'index.ts', 'index.tsx']) {
          if (fileExists(path.join(potentialPath, indexFile))) {
            return alias + correctedPath;
          }
        }
      }
    }
  }
  
  // Check for casing issues (case-sensitive file systems)
  const parts = pathAfterAlias.split('/');
  for (let i = 0; i < parts.length; i++) {
    const originalPart = parts[i];
    
    // Try lowercase
    parts[i] = originalPart.toLowerCase();
    const lowerPath = alias + parts.join('/');
    
    // Check if it exists
    for (const target of targets) {
      const potentialPath = path.join(baseUrl, target + parts.join('/'));
      if (directoryExists(potentialPath) || fileExists(potentialPath)) {
        return lowerPath;
      }
    }
    
    // Restore original
    parts[i] = originalPart;
  }
  
  return null;
}
